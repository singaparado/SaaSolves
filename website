  <script>
    /* ── SINGLE PAGE LIGHTWEIGHT ROUTER ── */
    function navigateTo(viewId, anchorId) {
      // Unmount all view sections
      const views = document.querySelectorAll('.view-panel');
      views.forEach(view => {
        view.classList.remove('active-view');
      });

      // Mount target view section
      const targetView = document.getElementById('view-' + viewId);
      if (targetView) {
        targetView.classList.add('active-view');
      }

      // Handle window resets and optional anchor jumps
      window.scrollTo(0, 0);
      if (anchorId) {
        setTimeout(() => {
          const anchorElement = document.getElementById(anchorId);
          if (anchorElement) {
            anchorElement.scrollIntoView({ behavior: 'smooth' });
          }
        }, 150);
      }
    }

    /* Keep fallback support for legacy nav clicks */
    function goTo(anchorId) {
      navigateTo('home', anchorId);
    }
    function goToAnchor(anchorId) {
      const el = document.getElementById(anchorId);
      if(el) el.scrollIntoView({ behavior: 'smooth' });
    }

    /* ── ORIGINAL MAIN SURFACE ACCORDION MECHANIC FOR LANDKNOT DIAGNOSIS ── */
    function toggleAccordion() {
      var content = document.getElementById("landknotContent");
      var icon = document.getElementById("toggleIcon");
      var header = document.getElementById("landknotToggle");
      
      header.classList.toggle("active");
      content.classList.toggle("open");
      
      if (content.classList.contains("open")) {
        icon.textContent = "−";
      } else {
        icon.textContent = "+";
      }
    }

    /* ── REVEAL SCROLL MONITOR RUNTIME ── */
    const revs = document.querySelectorAll('.reveal');
    function checkRev() {
      const trigger = window.innerHeight * 0.88;
      revs.forEach(r => {
        const top = r.getBoundingClientRect().top;
        if(top < trigger) { r.classList.add('in'); }
      });
    }
    window.addEventListener('scroll', checkRev);
    window.addEventListener('load', checkRev);

    /* ── DYNAMIC TYPING SIMULATOR RUNTIME ── */
    const words = ["translate your codebase.", "explain your infrastructure.", "secure technical buyers.", "align user onboarding."];
    let i = 0, j = 0, cur = "", del = false;
    const tw = document.getElementById("tw");
    
    function type() {
      const full = words[i];
      if (!del) {
        cur = full.substring(0, j + 1); j++;
        if (cur === full) { del = true; setTimeout(type, 2200); return; }
      } else {
        cur = full.substring(0, j - 1); j--;
        if (cur === "") { del = false; i = (i + 1) % words.length; }
      }
      tw.textContent = cur;
      setTimeout(type, del ? 35 : 65);
    }
    window.addEventListener('load', () => setTimeout(type, 600));
  </script>
